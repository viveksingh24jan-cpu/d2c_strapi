    "state": { "type": "string" },
    "pincode": { "type": "string" },
    "phone": { "type": "string" },
    "email": { "type": "email" },
    "workingHours": { "type": "string" },
    "latitude": { "type": "decimal" },
    "longitude": { "type": "decimal" }
  }
}
