{
  "kind": "collectionType",
  "collectionName": "annual_reports",
  "info": {
    "singularName": "annual-report",
    "pluralName": "annual-reports",
    "displayName": "AnnualReport"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "year": {
      "type": "string",
      "required": true
    },
    "reportType": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "annual-report",
        "esg-report",
        "stewardship-policy"
      ]
    },
    "file": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "files"
      ]
    },
    "publishedOn": {
      "type": "date"
    },
    "reportName": {
      "type": "string",
      "required": true
    }
  }
}
