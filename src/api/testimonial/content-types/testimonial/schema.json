{
  "kind": "collectionType",
  "collectionName": "testimonials",
  "info": {
    "singularName": "testimonial",
    "pluralName": "testimonials",
    "displayName": "Testimonial Registry",
    "description": "Master list of verified customer testimonials"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "customerName": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "customerName",
      "required": true
    },
    "customerTitle": {
      "type": "string",
      "description": "e.g. Verified Buyer, Car Insurance Customer"
    },
    "quote": {
      "type": "blocks",
      "required": true
    },
    "rating": {
      "type": "integer",
      "min": 1,
      "max": 5,
      "default": 5
    },
    "avatar": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "general",
        "motor",
        "health",
        "travel",
        "claims"
      ],
      "default": "general"
    },
    "isFeatured": {
      "type": "boolean",
      "default": false
    }
  }
}
