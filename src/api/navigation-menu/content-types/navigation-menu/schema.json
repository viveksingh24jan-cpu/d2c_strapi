{
  "kind": "collectionType",
  "collectionName": "navigation_menus",
  "info": {
    "singularName": "navigation-menu",
    "pluralName": "navigation-menus",
    "displayName": "NavigationMenu",
    "description": "Set location only on top-level items. Children inherit location through the parent tree. Supports unlimited nesting: parent → child → subchild → ..."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "label": {
      "type": "string",
      "required": true
    },
    "url": {
      "type": "string"
    },
    "location": {
      "type": "enumeration",
      "required": false,
      "enum": [
        "header",
        "footer_products",
        "footer_company",
        "footer_resources",
        "footer_legal"
      ]
    },
    "displayOrder": {
      "type": "integer",
      "default": 0
    },
    "isExternal": {
      "type": "boolean",
      "default": false
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "openInNewTab": {
      "type": "boolean",
      "default": false
    },
    "parent": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::navigation-menu.navigation-menu",
      "inversedBy": "children"
    },
    "children": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::navigation-menu.navigation-menu",
      "mappedBy": "parent"
    }
  }
}
