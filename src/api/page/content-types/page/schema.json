{
  "kind": "collectionType",
  "collectionName": "pages",
  "info": {
    "singularName": "page",
    "pluralName": "pages",
    "displayName": "Dynamic Landing Pages",
    "description": "Unified page model for Home, About, Legal, and Custom landing pages"
  },
  "options": {
    "draftAndPublish": true
  },
  "config": {
    "attributes": {
      "slug": {
        "previewUrl": "http://localhost:3000/preview/{slug}"
      }
    }
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "template": {
      "type": "enumeration",
      "enum": [
        "default",
        "home",
        "legal",
        "tool-hub",
        "grievance",
        "about"
      ],
      "default": "default"
    },
    "metadata": {
      "type": "component",
      "component": "shared.page-metadata",
      "repeatable": false
    },
    "content": {
      "type": "dynamiczone",
      "components": [
        "page-builder.hero-section",
        "page-builder.text-block",
        "page-builder.card-grid",
        "page-builder.media-block",
        "page-builder.accordion",
        "page-builder.testimonial-grid",
        "page-builder.video-block",
        "page-builder.comparison-table",
        "page-builder.app-banner",
        "page-builder.sticky-cta-bar",
        "page-builder.banner",
        "page-builder.progress-steps",
        "page-builder.stats-bar",
        "page-builder.product-showcase",
        "page-builder.featured-content",
        "page-builder.grievance-levels",
        "shared.rich-text",
        "shared.media",
        "shared.slider",
        "shared.alert",
        "shared.product-cta"
      ]
    },
    "seo": {
      "type": "component",
      "component": "shared.seo"
    },
    "internalNotes": {
      "type": "text",
      "description": "Internal notes for CM/Marketing team (not visible on frontend)."
    }
  }
}
