{
  "kind": "collectionType",
  "collectionName": "pages",
  "info": {
    "singularName": "page",
    "pluralName": "pages",
    "displayName": "Dynamic Landing Pages",
    "description": "Enterprise-grade unified page model with high-conversion builder sections"
  },
  "options": {
    "draftAndPublish": true
  },
  "config": {
    "attributes": {
      "slug": {
        "previewUrl": "http://localhost:3000/preview/{slug}"
      }
    }
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "description": "Internal page title for management"
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true,
      "description": "URL path (e.g. 'about-us')"
    },
    "template": {
      "type": "enumeration",
      "enum": [
        "default",
        "home",
        "legal",
        "tool-hub",
        "grievance",
        "about",
        "product-landing"
      ],
      "default": "default",
      "description": "Select a template for specific frontend layout logic"
    },
    "content": {
      "type": "dynamiczone",
      "components": [
        "page-builder.document-cta",
        "page-builder.document-listing",
        "page-builder.hero-section",
        "page-builder.text-block",
        "page-builder.card-grid",
        "page-builder.card-item",
        "page-builder.media-block",
        "page-builder.accordion",
        "page-builder.testimonial-showcase",
        "page-builder.comparison-table",
        "page-builder.banner",
        "page-builder.progress-steps",
        "page-builder.step-item",
        "page-builder.stats-bar",
        "page-builder.insurance-product-cta",
        "page-builder.featured-content",
        "page-builder.sticky-cta-bar",
        "shared.section-reference",
        "shared.stats-item",
        "shared.seo",
        "shared.social-link",
        "shared.link",
        "shared.app-links",
        "shared.award"
      ],
      "description": "High-conversion building blocks for creating visual layouts"
    },
    "seo": {
      "type": "component",
      "component": "shared.seo",
      "description": "SEO & Social Sharing configuration"
    },
    "uiConfig": {
      "type": "component",
      "component": "shared.ui-config"
    },
    "internalNotes": {
      "type": "text",
      "description": "Internal notes for Content/Marketing team (not visible on frontend)."
    }
  }
}
