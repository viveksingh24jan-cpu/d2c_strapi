{
  "kind": "collectionType",
  "collectionName": "pages",
  "info": {
    "singularName": "page",
    "pluralName": "pages",
    "displayName": "Dynamic Landing Pages",
    "description": "Unified page model for Home, About, Legal, and Custom landing pages"
  },
  "options": {
    "draftAndPublish": true
  },
  "config": {
    "attributes": {
      "slug": {
        "previewUrl": "http://localhost:3000/preview/{slug}"
      }
    }
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "template": {
      "type": "enumeration",
      "enum": [
        "default",
        "home",
        "legal",
        "tool-hub",
        "grievance",
        "about"
      ],
      "default": "default"
    },
    "hero": {
      "type": "component",
      "component": "shared.hero",
      "repeatable": false
    },
    "metadata": {
      "type": "component",
      "component": "shared.page-metadata",
      "repeatable": false
    },
    "blocks": {
      "type": "dynamiczone",
      "components": [
        "shared.slider",
        "shared.rich-text",
        "shared.quote",
        "shared.media",
        "shared.faq-item",
        "shared.process-step",
        "shared.award",
        "shared.lottie",
        "shared.alert",
        "shared.modal",
        "shared.product-cta",
        "shared.dynamic-comparison",
        "shared.compliance-banner",
        "shared.section-reference",
        "shared.featured-tools",
        "shared.comparison-table",
        "shared.stats",
        "shared.promo-card"
      ]
    },
    "seo": {
      "type": "component",
      "component": "shared.seo"
    },
    "internalNotes": {
      "type": "text",
      "description": "Internal notes for CM/Marketing team (not visible on frontend)."
    }
  }
}
