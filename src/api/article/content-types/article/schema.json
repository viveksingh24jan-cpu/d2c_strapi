{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Article",
    "description": "Blog posts and articles with standardized page builder"
  },
  "options": {
    "draftAndPublish": true
  },
  "config": {
    "attributes": {
      "slug": {
        "previewUrl": "http://localhost:3000/blog/preview/{slug}"
      }
    }
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 200
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "excerpt": {
      "type": "text",
      "maxLength": 300
    },
    "cover": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "authorName": {
      "type": "string"
    },
    "readTime": {
      "type": "integer"
    },
    "author": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::author.author",
      "inversedBy": "articles"
    },
    "isFeatured": {
      "type": "boolean",
      "default": false
    },
    "categories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::category.category",
      "inversedBy": "articles"
    },
    "blocks": {
      "type": "dynamiczone",
      "components": [
        "page-builder.document-cta",
        "page-builder.document-listing",
        "page-builder.banner",
        "page-builder.hero-section",
        "page-builder.text-block",
        "page-builder.card-grid",
        "page-builder.media-block",
        "page-builder.accordion",
        "page-builder.testimonial-showcase",
        "page-builder.comparison-table",
        "page-builder.progress-steps",
        "page-builder.stats-bar",
        "page-builder.insurance-product-cta",
        "page-builder.featured-content",
        "page-builder.sticky-cta-bar",
        "page-builder.cta-section",
        "page-builder.tabs",
        "page-builder.modals",
        "page-builder.charts",
        "shared.section-reference"
      ]
    },
    "seo": {
      "type": "component",
      "component": "shared.seo"
    },
    "cta": {
      "type": "component",
      "component": "shared.cta"
    },
    "uiConfig": {
      "type": "component",
      "component": "shared.ui-config"
    }
  }
}
