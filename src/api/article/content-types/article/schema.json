{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Article",
    "description": "Blog posts and articles"
  },
  "options": {
    "draftAndPublish": true
  },
  "config": {
    "attributes": {
      "slug": {
        "previewUrl": "http://localhost:3000/blog/preview/{slug}"
      }
    }
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 200
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "excerpt": {
      "type": "text",
      "maxLength": 300
    },
    "cover": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "authorName": {
      "type": "string"
    },
    "readTime": {
      "type": "integer"
    },
    "author": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::author.author",
      "inversedBy": "articles"
    },
    "isFeatured": {
      "type": "boolean",
      "default": false
    },
    "categories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::category.category",
      "inversedBy": "articles"
    },
    "blocks": {
      "type": "dynamiczone",
      "components": [
        "shared.slider",
        "shared.rich-text",
        "shared.quote",
        "shared.media",
        "shared.faq-item",
        "shared.process-step",
        "shared.award",
        "shared.lottie",
        "shared.alert",
        "shared.modal",
        "shared.product-cta",
        "shared.dynamic-comparison",
        "shared.compliance-banner",
        "shared.section-reference",
        "shared.featured-tools",
        "shared.comparison-table"
      ]
    },
    "seo": {
      "type": "component",
      "component": "shared.seo",
      "repeatable": false
    }
  }
}
