{
  "kind": "collectionType",
  "collectionName": "public_disclosures",
  "info": {
    "singularName": "download-document",
    "pluralName": "download-documents",
    "displayName": "Unified Public Disclosure",
    "description": "Consolidated registry for single policies and quarterly NL-Schedule sets (NL-1 to NL-47)"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "category": {
      "type": "enumeration",
      "enum": ["Regulatory", "Financial", "Governance", "Metrics"],
      "required": true
    },
    "disclosureType": {
      "type": "enumeration",
      "enum": ["single_document", "quarterly_nl_set"],
      "default": "single_document",
      "required": true
    },
    "financialYear": {
      "type": "string",
      "regex": "^20[0-9]{2}-[0-9]{2}$",
      "description": "e.g. 2024-25"
    },
    "quarter": {
      "type": "enumeration",
      "enum": ["Q1", "Q2", "Q3", "Q4", "Annual"]
    },
    "actionType": {
      "type": "enumeration",
      "enum": ["pdf_viewer", "docx_viewer", "internal_page", "external_link"],
      "default": "pdf_viewer",
      "description": "Used for single document entries"
    },
    "fileAsset": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["files"]
    },
    "internalLink": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::page.page"
    },
    "externalUrl": {
      "type": "string"
    },
    "nestedSchedules": {
      "type": "component",
      "repeatable": true,
      "component": "disclosures.disclosure-document",
      "description": "Used for quarterly sets (NL-1 to NL-47)"
    },
    "publishDate": {
      "type": "date",
      "required": true
    }
  }
}
