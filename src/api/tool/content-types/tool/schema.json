{
  "kind": "collectionType",
  "collectionName": "tools",
  "info": {
    "singularName": "tool",
    "pluralName": "tools",
    "displayName": "Financial Tools & Calculators",
    "description": "Unified registry for all customer tools (Calculators, Challan Checkers, ABHA Generators)"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "calculator",
        "checker",
        "generator",
        "lookup",
        "resource"
      ],
      "default": "calculator",
      "required": true
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "motor",
        "health",
        "travel",
        "generic"
      ],
      "default": "generic"
    },
    "shortDescription": {
      "type": "text",
      "maxLength": 300
    },
    "longDescription": {
      "type": "blocks"
    },
    "icon": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "area": {
      "type": "enumeration",
      "enum": [
        "public-site",
        "customer-portal",
        "agent-portal",
        "mobile-app"
      ],
      "default": "public-site"
    },
    "cta": {
      "type": "component",
      "repeatable": false,
      "component": "shared.link"
    },
    "badge": {
      "type": "enumeration",
      "enum": [
        "New",
        "Popular",
        "Trending",
        "Free"
      ]
    },
    "seo": {
      "type": "component",
      "component": "shared.seo",
      "repeatable": false
    }
  }
}
