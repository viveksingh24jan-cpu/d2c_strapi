{
  "kind": "collectionType",
  "collectionName": "tools",
  "info": {
    "singularName": "tool",
    "pluralName": "tools",
    "displayName": "Tool"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name"
    },
    "shortDescription": {
      "type": "text",
      "maxLength": 300
    },
    "icon": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "url": {
      "type": "string"
    },
    "isExternal": {
      "type": "boolean",
      "default": false
    },
    "isActive": {
      "type": "boolean",
      "default": false
    },
    "badge": {
      "type": "enumeration",
      "enum": [
        "New",
        "Popular",
        "Trending",
        "Free"
      ]
    },
    "tool_category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::tool-category.tool-category",
      "inversedBy": "tools"
    },
    "seo": {
      "type": "component",
      "component": "shared.seo",
      "repeatable": false
    }
  }
}
