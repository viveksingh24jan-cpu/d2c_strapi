{
  "kind": "collectionType",
  "collectionName": "financial_quarters",
  "info": {
    "singularName": "financial-quarter",
    "pluralName": "financial-quarters",
    "displayName": "FinancialQuarter"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "quarter": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "Q1",
        "Q2",
        "Q3",
        "Q4"
      ]
    },
    "documents": {
      "type": "component",
      "component": "disclosures.disclosure-document",
      "repeatable": true
    },
    "financialYear": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::financial-year.financial-year"
    }
  }
}
