{
  "kind": "singleType",
  "collectionName": "global_configs",
  "info": {
    "singularName": "global-config",
    "pluralName": "global-configs",
    "displayName": "Global Site Configuration",
    "description": "Master settings for branding, regulatory info, and IRDAI-compliant footer columns"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "siteName": {
      "type": "string",
      "required": true
    },
    "siteDescription": {
      "type": "text",
      "required": true
    },
    "favicon": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "defaultSeo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    },
    "cinNumber": {
      "type": "string"
    },
    "irdaiRegNumber": {
      "type": "string",
      "required": true
    },
    "registeredAddress": {
      "type": "text",
      "required": true
    },
    "section41Warning": {
      "type": "blocks"
    },
    "irdaiUrl": {
      "type": "string"
    },
    "gicUrl": {
      "type": "string"
    },
    "bimaBharosaUrl": {
      "type": "string"
    },
    "headerLogo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "headerPhoneNumber": {
      "type": "string"
    },
    "headerEmailAddress": {
      "type": "email"
    },
    "supportEmail": {
      "type": "email"
    },
    "footerDescription": {
      "type": "text"
    },
    "footerLogo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "footer_products": {
      "type": "component",
      "repeatable": false,
      "component": "shared.footer-column"
    },
    "footer_company": {
      "type": "component",
      "repeatable": false,
      "component": "shared.footer-column"
    },
    "footer_resources": {
      "type": "component",
      "repeatable": false,
      "component": "shared.footer-column"
    },
    "footer_legal": {
      "type": "component",
      "repeatable": false,
      "component": "shared.footer-column"
    },
    "socialLinks": {
      "type": "component",
      "component": "shared.social-link",
      "repeatable": true
    },
    "appLinks": {
      "type": "component",
      "component": "shared.app-links",
      "repeatable": false
    },
    "footerCopyright": {
      "type": "text"
    },
    "analytics": {
      "type": "component",
      "component": "shared.scripts",
      "repeatable": false
    },
    "stickyCta": {
      "type": "component",
      "component": "page-builder.sticky-cta-bar",
      "repeatable": false
    },
    "trustMetrics": {
      "type": "component",
      "component": "shared.stats-item",
      "repeatable": true
    }
  }
}
