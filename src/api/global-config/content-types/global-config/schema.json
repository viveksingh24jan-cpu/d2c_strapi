{
  "kind": "singleType",
  "collectionName": "global_configs",
  "info": {
    "singularName": "global-config",
    "pluralName": "global-configs",
    "displayName": "GlobalConfig"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "siteName": {
      "type": "string",
      "required": true
    },
    "siteDescription": {
      "type": "text",
      "required": true
    },
    "favicon": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "defaultSeo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    },
    "cinNumber": {
      "type": "string"
    },
    "irdaiRegNumber": {
      "type": "string",
      "required": true
    },
    "registeredAddress": {
      "type": "text",
      "required": true
    },
    "section41Warning": {
      "type": "blocks"
    },
    "irdaiUrl": {
      "type": "string"
    },
    "gicUrl": {
      "type": "string"
    },
    "bimaBharosaUrl": {
      "type": "string"
    },
    "headerLogo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "headerPhoneNumber": {
      "type": "string"
    },
    "headerEmailAddress": {
      "type": "string"
    },
    "footerDescription": {
      "type": "text"
    },
    "footerLogo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "privacyPage": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::legal-page.legal-page"
    },
    "termsPage": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::legal-page.legal-page"
    },
    "supportEmail": {
      "type": "string"
    },
    "socialLinks": {
      "type": "component",
      "component": "shared.social-link",
      "repeatable": true
    },
    "appLinks": {
      "type": "component",
      "component": "shared.app-links",
      "repeatable": false
    },
    "footerCopyright": {
      "type": "text"
    },
    "announcementBanner": {
      "type": "component",
      "component": "shared.announcement-banner",
      "repeatable": false
    },
    "stickyCtaText": {
      "type": "string"
    },
    "stickyCtaUrl": {
      "type": "string"
    },
    "stickyCtaIsActive": {
      "type": "boolean",
      "default": false
    }
  }
}
