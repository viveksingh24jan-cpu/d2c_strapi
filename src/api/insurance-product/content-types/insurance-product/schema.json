{
  "kind": "collectionType",
  "collectionName": "insurance_products",
  "info": {
    "singularName": "insurance-product",
    "pluralName": "insurance-products",
    "displayName": "InsuranceProduct",
    "description": "Master Products (4W, 2W) with Dynamic Page Builder and optimized sorting"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "productName": {
      "type": "string",
      "required": true
    },
    "identifier": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "productName",
      "required": true
    },
    "productLabel": {
      "type": "enumeration",
      "enum": [
        "New",
        "Best Seller",
        "Tax Saving",
        "Recommended",
        "Limited Offer"
      ]
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    },
    "isVisibleOnHomepage": {
      "type": "boolean",
      "default": false
    },
    "lineOfBusiness": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::line-of-business.line-of-business",
      "inversedBy": "insuranceProducts"
    },
    "insurancePlans": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::insurance-plan.insurance-plan",
      "inversedBy": "insuranceProducts"
    },
    "cardIcon": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "heroHeading": {
      "type": "string"
    },
    "heroDescription": {
      "type": "text"
    },
    "pageBuilder": {
      "type": "dynamiczone",
      "components": [
        "page-builder.product-grid",
        "page-builder.document-cta",
        "page-builder.document-listing",
        "page-builder.banner",
        "page-builder.hero-section",
        "page-builder.text-block",
        "page-builder.card-grid",
        "page-builder.media-block",
        "page-builder.accordion",
        "page-builder.testimonial-showcase",
        "page-builder.comparison-table",
        "page-builder.progress-steps",
        "page-builder.stats-bar",
        "page-builder.insurance-product-cta",
        "page-builder.featured-content",
        "page-builder.sticky-cta-bar",
        "page-builder.cta-section",
        "page-builder.tabs",
        "page-builder.modals",
        "page-builder.charts",
        "shared.section-reference"
      ]
    },
    "keyBenefits": {
      "type": "component",
      "component": "product.key-benefit",
      "repeatable": true
    },
    "seo": {
      "type": "component",
      "component": "shared.seo"
    },
    "cta": {
      "type": "component",
      "component": "shared.cta"
    },
    "uiConfig": {
      "type": "component",
      "component": "shared.ui-config"
    },
    "isEmiAvailable": {
      "type": "boolean",
      "required": true,
      "default": false
    },
    "uinNumber": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "isActive": {
      "type": "boolean",
      "required": true,
      "default": true
    },
    "isMonthlyAvailable": {
      "type": "boolean",
      "required": true,
      "default": false
    },
    "isWithdrawn": {
      "type": "boolean",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": ""
            },
            ""
          ]
        }
      },
      "required": true,
      "default": false
    }
  }
}
