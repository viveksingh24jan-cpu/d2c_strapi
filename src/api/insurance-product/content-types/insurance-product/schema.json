{
  "kind": "collectionType",
  "collectionName": "insurance_products",
  "info": {
    "singularName": "insurance-product",
    "pluralName": "insurance-products",
    "displayName": "InsuranceProduct"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "productName": {
      "type": "string"
    },
    "productDescription": {
      "type": "blocks"
    },
    "startingPrice": {
      "type": "decimal"
    },
    "pricePrefix": {
      "type": "string",
      "default": "Starting at"
    },
    "priceSuffix": {
      "type": "string",
      "default": "/year"
    },
    "isFeatured": {
      "type": "boolean"
    },
    "tagline": {
      "type": "string",
      "required": true
    },
    "badge": {
      "type": "string"
    },
    "ctaText": {
      "type": "string",
      "required": true
    },
    "ctaUrl": {
      "type": "string",
      "required": true
    },
    "isActive": {
      "type": "boolean",
      "required": true
    },
    "sortOrder": {
      "type": "integer",
      "required": true
    },
    "icon": {
      "type": "media",
      "multiple": true,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "blocks": {
      "type": "dynamiczone",
      "components": [
        "page-builder.hero-section",
        "page-builder.text-block",
        "page-builder.card-grid",
        "page-builder.media-block",
        "page-builder.accordion",
        "page-builder.video-block",
        "page-builder.comparison-table",
        "page-builder.app-banner",
        "page-builder.banner",
        "page-builder.progress-steps",
        "page-builder.stats-bar",
        "page-builder.product-showcase",
        "page-builder.featured-content",
        "page-builder.insurance-product-cta",
        "shared.comparison-table"
      ]
    },
    "seo": {
      "type": "component",
      "component": "shared.seo",
      "repeatable": false
    }
  }
}
