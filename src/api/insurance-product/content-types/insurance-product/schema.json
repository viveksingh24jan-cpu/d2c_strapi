{
  "kind": "collectionType",
  "collectionName": "insurance_products",
  "info": {
    "singularName": "insurance-product",
    "pluralName": "insurance-products",
    "displayName": "InsuranceProduct"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "productName": {
      "type": "string"
    },
    "productDescription": {
      "type": "blocks"
    },
    "startingPrice": {
      "type": "decimal"
    },
    "pricePrefix": {
      "type": "string",
      "default": "Starting at"
    },
    "priceSuffix": {
      "type": "string",
      "default": "/year"
    },
    "isFeatured": {
      "type": "boolean"
    },
    "tagline": {
      "type": "string",
      "required": true
    },
    "badge": {
      "type": "string"
    },
    "ctaText": {
      "type": "string",
      "required": true
    },
    "ctaUrl": {
      "type": "string",
      "required": true
    },
    "isActive": {
      "type": "boolean",
      "required": true
    },
    "sortOrder": {
      "type": "integer",
      "required": true
    },
    "icon": {
      "type": "media",
      "multiple": true,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "blocks": {
      "type": "dynamiczone",
      "components": [
        "shared.slider",
        "shared.rich-text",
        "shared.quote",
        "shared.media",
        "shared.faq-item",
        "shared.process-step",
        "shared.comparison-table",
        "shared.award",
        "shared.lottie",
        "shared.alert",
        "shared.modal",
        "shared.product-cta",
        "shared.dynamic-comparison",
        "shared.compliance-banner"
      ]
    },
    "seo": {
      "type": "component",
      "component": "shared.seo",
      "repeatable": false
    }
  }
}
