{
  "kind": "collectionType",
  "collectionName": "insurance_products",
  "info": {
    "singularName": "insurance-product",
    "pluralName": "insurance-products",
    "displayName": "InsuranceProduct"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "productName": {
      "type": "string",
      "required": true
    },
    "isStandard": {
      "type": "boolean",
      "default": false,
      "description": "True if this is an IRDAI mandated standard product (e.g. Arogya Sanjeevani)"
    },
    "productType": {
      "type": "enumeration",
      "enum": [
        "generic",
        "arogya-sanjeevani",
        "saral-suraksha-bima",
        "bharat-griha-raksha",
        "bharat-sookshma-udyam",
        "bharat-laghu-udyam"
      ],
      "default": "generic"
    },
    "complianceFeatures": {
      "type": "blocks",
      "description": "Standardized features for regulatory compliance"
    },
    "eligibility": {
      "type": "blocks"
    },
    "cisDocument": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["files"]
    },
    "policyWording": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["files"]
    },
    "productDescription": {
      "type": "blocks"
    },
    "uinNumber": {
      "type": "string",
      "description": "Unique Identification Number assigned by IRDAI"
    },
    "startingPrice": {
      "type": "decimal"
    },
    "pricePrefix": {
      "type": "string",
      "default": "Starting at"
    },
    "priceSuffix": {
      "type": "string",
      "default": "/year"
    },
    "isFeatured": {
      "type": "boolean"
    },
    "tagline": {
      "type": "string",
      "required": true
    },
    "badge": {
      "type": "string"
    },
    "ctaText": {
      "type": "string",
      "required": true
    },
    "ctaUrl": {
      "type": "string",
      "required": true
    },
    "isActive": {
      "type": "boolean",
      "required": true
    },
    "sortOrder": {
      "type": "integer",
      "required": true
    },
    "icon": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "blocks": {
      "type": "dynamiczone",
      "components": [
        "page-builder.hero-section",
        "page-builder.text-block",
        "page-builder.card-grid",
        "page-builder.card-item",
        "page-builder.media-block",
        "page-builder.accordion",
        "page-builder.testimonial-showcase",
        "page-builder.comparison-table",
        "page-builder.banner",
        "page-builder.progress-steps",
        "page-builder.step-item",
        "page-builder.stats-bar",
        "page-builder.insurance-product-cta",
        "page-builder.featured-content",
        "page-builder.sticky-cta-bar",
        "shared.stats-item",
        "shared.social-link",
        "shared.link",
        "shared.award"
      ]
    },
    "seo": {
      "type": "component",
      "component": "shared.seo",
      "repeatable": false
    }
  }
}
