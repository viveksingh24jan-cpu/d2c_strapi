{
  "kind": "collectionType",
  "collectionName": "standard_products",
  "info": {
    "singularName": "standard-product",
    "pluralName": "standard-products",
    "displayName": "StandardProduct"
  },
  "options": { "draftAndPublish": true },
  "pluginOptions": {},
  "attributes": {
    "productName": { "type": "string", "required": true },
    "productType": {
      "type": "enumeration",
      "enum": ["arogya-sanjeevani", "saral-suraksha-bima", "bharat-griha-raksha", "bharat-sookshma-udyam", "bharat-laghu-udyam"],
      "required": true
    },
    "features": { "type": "blocks" },
    "eligibility": { "type": "blocks" },
    "sumInsuredRange": { "type": "string" },
    "premiumRange": { "type": "string" },
    "cisDocument": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["files"]
    },
    "policyWording": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["files"]
    },
    "blocks": {
      "type": "dynamiczone",
      "components": [
        "shared.slider",
        "shared.rich-text",
        "shared.quote",
        "shared.media",
        "shared.faq-item",
        "shared.process-step",
        "shared.comparison-table",
        "shared.award",
        "shared.lottie",
        "shared.alert",
        "shared.modal",
        "shared.product-cta",
        "shared.dynamic-comparison",
        "shared.compliance-banner"
      ]
    },
    "isActive": { "type": "boolean", "default": true }
  }
}
