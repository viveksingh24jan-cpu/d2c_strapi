{
  "kind": "collectionType",
  "collectionName": "financial_disclosures",
  "info": {
    "singularName": "financial-disclosure",
    "pluralName": "financial-disclosures",
    "displayName": "Financial Disclosure",
    "description": "Quarterly results, annual reports, ESG reports, and public disclosures"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "disclosureType": {
      "type": "enumeration",
      "enum": [
        "quarterly-result",
        "annual-report",
        "esg-report",
        "stewardship-policy",
        "public-disclosure"
      ],
      "required": true
    },
    "financialYear": {
      "type": "string",
      "required": true
    },
    "quarter": {
      "type": "enumeration",
      "enum": ["Q1", "Q2", "Q3", "Q4"]
    },
    "documents": {
      "type": "component",
      "repeatable": true,
      "component": "disclosures.disclosure-document"
    },
    "publishedOn": {
      "type": "date"
    }
  }
}
