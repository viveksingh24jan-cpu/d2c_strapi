{
  "kind": "collectionType",
  "collectionName": "partners",
  "info": {
    "singularName": "partner",
    "pluralName": "partners",
    "displayName": "Partner",
    "description": "Network partners (hospitals, garages) and brand partnerships"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "partnerName": {
      "type": "string",
      "required": true
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images"]
    },
    "websiteUrl": {
      "type": "string"
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "hospital",
        "garage",
        "brand",
        "investor"
      ],
      "default": "brand"
    }
  }
}
