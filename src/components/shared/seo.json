{
  "collectionName": "components_shared_seos",
  "info": {
    "displayName": "Advanced SEO",
    "icon": "search",
    "description": "Enterprise-grade SEO with Robots and Structured Data"
  },
  "options": {},
  "attributes": {
    "metaTitle": {
      "type": "string",
      "required": true
    },
    "metaDescription": {
      "type": "text",
      "required": true
    },
    "metaImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "metaKeywords": {
      "type": "text"
    },
    "metaRobots": {
      "type": "string",
      "default": "index, follow",
      "description": "e.g., noindex, nofollow"
    },
    "canonicalURL": {
      "type": "string"
    },
    "structuredData": {
      "type": "json",
      "description": "JSON-LD for Schema.org"
    }
  }
}
