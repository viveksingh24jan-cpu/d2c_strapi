{
  "collectionName": "components_shared_product_ctas",
  "info": {
    "displayName": "Product CTA",
    "icon": "shopping-cart",
    "description": "Dynamic product card that pulls data from the Product Registry (Single Source of Truth)"
  },
  "options": {},
  "attributes": {
    "product": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::insurance-product.insurance-product"
    },
    "customTitle": {
      "type": "string",
      "description": "Override the product name if needed"
    },
    "customSubtitle": {
      "type": "text",
      "description": "Override the product tagline if needed"
    },
    "variant": {
      "type": "enumeration",
      "enum": [
        "card",
        "banner",
        "minimal"
      ],
      "default": "card",
      "required": true
    },
    "isFeatured": {
      "type": "boolean",
      "default": false
    }
  }
}
