{
  "collectionName": "components_shared_link",
  "info": {
    "displayName": "Link",
    "description": "Reusable link/CTA button",
    "icon": "link"
  },
  "options": {},
  "attributes": {
    "label": {
      "type": "string",
      "required": true
    },
    "url": {
      "type": "string",
      "required": true
    },
    "target": {
      "type": "enumeration",
      "enum": ["_self", "_blank"],
      "default": "_self"
    },
    "variant": {
      "type": "enumeration",
      "enum": ["primary", "secondary", "outline", "text"],
      "default": "primary"
    }
  }
}
