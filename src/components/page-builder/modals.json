{
  "collectionName": "components_page_builder_modals",
  "info": {
    "displayName": "Modal Overlay",
    "description": "Configurable popup modal content",
    "icon": "expand"
  },
  "options": {},
  "attributes": {
    "modalId": {
      "type": "string",
      "required": true,
      "description": "Unique identifier to trigger this modal"
    },
    "title": {
      "type": "string"
    },
    "content": {
      "type": "blocks"
    },
    "size": {
      "type": "enumeration",
      "enum": ["small", "medium", "large", "full-screen"],
      "default": "medium"
    },
    "triggerOnLoad": {
      "type": "boolean",
      "default": false
    },
    "delaySeconds": {
      "type": "integer",
      "default": 0
    }
  }
}
