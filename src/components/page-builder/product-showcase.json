{
  "collectionName": "components_page_builder_product_showcase",
  "info": {
    "displayName": "Product Showcase",
    "description": "Insurance product carousel/grid display",
    "icon": "shoppingCart"
  },
  "options": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "subtitle": {
      "type": "text"
    },
    "products": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::insurance-product.insurance-product"
    },
    "layout": {
      "type": "enumeration",
      "enum": [
        "carousel",
        "grid",
        "list"
      ],
      "default": "carousel"
    },
    "showPrice": {
      "type": "boolean",
      "default": true
    },
    "maxDisplay": {
      "type": "integer"
    }
  }
}
