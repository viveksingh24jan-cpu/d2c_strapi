{
  "collectionName": "components_page_builder_card_grid",
  "info": {
    "displayName": "Card Grid",
    "description": "Configurable grid of card items",
    "icon": "apps"
  },
  "options": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "subtitle": {
      "type": "text"
    },
    "cards": {
      "type": "component",
      "repeatable": true,
      "component": "page-builder.card-item"
    },
    "layout": {
      "type": "enumeration",
      "enum": [
        "grid-2",
        "grid-3",
        "grid-4",
        "masonry",
        "bento-grid"
      ],
      "default": "grid-3"
    },
    "customClassName": {
      "type": "string",
      "description": "Optional CSS class for custom grid styling"
    }
  }
}
