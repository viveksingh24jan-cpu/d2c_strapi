{
  "collectionName": "components_page_builder_banner",
  "info": {
    "displayName": "Banner",
    "description": "Announcement, promo, alert, or info banner strip",
    "icon": "bell"
  },
  "options": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "content": {
      "type": "blocks"
    },
    "bannerType": {
      "type": "enumeration",
      "enum": [
        "announcement",
        "promo",
        "alert",
        "info",
        "app-promotion"
      ],
      "default": "info"
    },
    "appLinks": {
      "type": "component",
      "repeatable": false,
      "component": "shared.app-links"
    },
    "qrCode": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "backgroundColor": {
      "type": "string"
    },
    "icon": {
      "type": "string"
    },
    "ctaButton": {
      "type": "component",
      "repeatable": false,
      "component": "shared.link"
    },
    "dismissible": {
      "type": "boolean",
      "default": false
    }
  }
}
