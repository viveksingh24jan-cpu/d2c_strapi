{
  "info": {
    "name": "Kiwi General Insurance – Strapi API",
    "description": "Full API test collection for Kiwi General Insurance Strapi backend. Base URL: http://localhost:1337/api\n\nTips:\n- Use `?populate=*` to get related data\n- Use `?pagination[pageSize]=25` to control page size\n- Use `?filters[field][$eq]=value` to filter\n- Use `?sort=field:asc` or `field:desc` to sort\n- Replace `:documentId` with an actual documentId from a list response",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "kiwi-general-insurance-2025"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:1337/api", "type": "string" },
    { "key": "documentId", "value": "REPLACE_WITH_ACTUAL_DOCUMENT_ID", "type": "string" }
  ],
  "item": [

    {
      "name": "🏠 Homepage",
      "item": [
        {
          "name": "Get Homepage",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/homepage?populate=*", "host": ["{{baseUrl}}"], "path": ["homepage"], "query": [{ "key": "populate", "value": "*" }] },
            "description": "Returns the single Homepage entry with all fields populated."
          }
        },
        {
          "name": "Get Homepage (with SEO + Stats)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/homepage?populate[seo]=*&populate[stats]=*&populate[promoCards]=*&populate[insuranceProducts][populate]=*", "host": ["{{baseUrl}}"], "path": ["homepage"] },
            "description": "Deep populate homepage with SEO, stats, promoCards, and related insurance products."
          }
        }
      ]
    },

    {
      "name": "🧭 Navigation Menus",
      "item": [
        {
          "name": "Get All Nav Items",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/navigation-menus?populate=*&pagination[pageSize]=200&sort=displayOrder:asc", "host": ["{{baseUrl}}"], "path": ["navigation-menus"] },
            "description": "Returns all navigation menu items with parent/children. Use sort and pagination for large sets."
          }
        },
        {
          "name": "Get Header Top-Level Items",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/navigation-menus?filters[location][$eq]=header&filters[parent][id][$null]=true&sort=displayOrder:asc&populate=children", "host": ["{{baseUrl}}"], "path": ["navigation-menus"] },
            "description": "Returns only the top-level header items (Products, Claims, Resources)."
          }
        },
        {
          "name": "Get Full Header Tree",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/navigation-menus?filters[location][$eq]=header&populate[children][populate][children][populate]=*&sort=displayOrder:asc", "host": ["{{baseUrl}}"], "path": ["navigation-menus"] },
            "description": "Returns the full 3-level header navigation tree (top-level → categories → sub-links)."
          }
        },
        {
          "name": "Get Footer Products Links",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/navigation-menus?filters[location][$eq]=footer_products&sort=displayOrder:asc", "host": ["{{baseUrl}}"], "path": ["navigation-menus"] }
