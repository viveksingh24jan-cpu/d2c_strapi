{
  "info": {
    "name": "Kiwi General Insurance – D2C CMS API (Final Handover)",
    "description": "Comprehensive API collection for the optimized Insurance D2C CMS with recursive N-level nesting.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:1337/api",
      "type": "string"
    },
    {
      "key": "jwt",
      "value": "REPLACE_WITH_JWT_TOKEN",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwt}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "🚀 Global & Bootstrap",
      "item": [
        {
          "name": "1. Site Bootstrap (Full Config + Navigation)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/bootstrap",
              "host": ["{{baseUrl}}"],
              "path": ["bootstrap"]
            },
            "description": "Fetch Global Config, Navigation Menus, and Homepage SEO in a single call."
          }
        },
        {
          "name": "2. Global Config Only",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/global-config?populate=*",
              "host": ["{{baseUrl}}"],
              "path": ["global-config"]
            },
            "description": "Fetch master branding, regulatory info, and CIN/IRDAI numbers."
          }
        }
      ]
    },
    {
      "name": "📄 Dynamic Pages (Enriched)",
      "item": [
        {
          "name": "Home Page (Product Selection)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/pages/index",
              "host": ["{{baseUrl}}"],
              "path": ["pages", "index"]
            },
            "description": "Fetch the homepage. The 'product-grid' will be automatically enriched with products marked 'Visible on Homepage'."
          }
        },
        {
          "name": "Public Disclosures (Document Listing)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/pages/public-disclosures",
              "host": ["{{baseUrl}}"],
              "path": ["pages", "public-disclosures"]
            },
            "description": "Fetch the disclosures page. 'document-listing' will be enriched with real document records."
          }
        },
        {
          "name": "Branch List (Branch Locator)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/pages/branch-list",
              "host": ["{{baseUrl}}"],
              "path": ["pages", "branch-list"]
            },
            "description": "Fetch branch list page. 'branch-locator' will be enriched with all branch records."
          }
        },
        {
          "name": "Grievance Redressal (Accordion & Nesting)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/pages/grievance-redressal",
              "host": ["{{baseUrl}}"],
              "path": ["pages", "grievance-redressal"]
            },
            "description": "Fetch grievance page with complex nested blocks and escalation matrix."
          }
        }
      ]
    },
    {
      "name": "🚗 Insurance Hierarchy (4W/2W)",
      "item": [
        {
          "name": "1. Product Landing (e.g. Car Insurance)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/insurance-products/car-insurance",
              "host": ["{{baseUrl}}"],
              "path": ["insurance-products", "car-insurance"]
            },
            "description": "Fetch a specific product page with its full 'pageBuilder' dynamic zone and enriched data."
          }
        },
        {
          "name": "2. Plans for Product (Car Insurance Platinum)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/insurance-plans?filters[insuranceProducts][slug][$eq]=car-insurance&populate=*",
              "host": ["{{baseUrl}}"],
              "path": ["insurance-plans"]
            },
            "description": "Fetch all plans (Platinum, Gold, etc.) associated with a specific vehicle product."
          }
        },
        {
          "name": "3. Coverage Lookup (Keyword Search)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/coverages?filters[identifier][$eq]=COV_1&populate=*",
              "host": ["{{baseUrl}}"],
              "path": ["coverages"]
            },
            "description": "Directly lookup technical coverage content by keyword (e.g., ZERO_DEP) for the quote engine."
          }
        }
      ]
    },
    {
      "name": "📰 Articles & Blog",
      "item": [
        {
          "name": "Single Article (Enriched)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/articles/the-internet-s-own-boy",
              "host": ["{{baseUrl}}"],
              "path": ["articles", "the-internet-s-own-boy"]
            },
            "description": "Fetch a blog post. Its 'blocks' (Dynamic Zone) will be enriched just like standard pages."
          }
        }
      ]
    },
    {
      "name": "🗺️ Navigation & Menus",
      "item": [
        {
          "name": "Fetch Header Menu",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/navigation-menus?filters[location][$eq]=header&sort=displayOrder:asc&populate=*",
              "host": ["{{baseUrl}}"],
              "path": ["navigation-menus"]
            },
            "description": "Fetch top-level header navigation links."
          }
        },
        {
          "name": "Fetch Footer Menu Tree",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/navigation-menus?filters[location][$contains]=footer&populate[children][populate]=*",
              "host": ["{{baseUrl}}"],
              "path": ["navigation-menus"]
            },
            "description": "Fetch footer columns and their nested links."
          }
        }
      ]
    }
  ]
}
