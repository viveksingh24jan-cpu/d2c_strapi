        },
        {
          "name": "Get Footer Company Links",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/navigation-menus?filters[location][$eq]=footer_company&sort=displayOrder:asc", "host": ["{{baseUrl}}"], "path": ["navigation-menus"] }
