        {
          "name": "Get Footer Legal Links",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/navigation-menus?filters[location][$eq]=footer_legal&sort=displayOrder:asc", "host": ["{{baseUrl}}"], "path": ["navigation-menus"] }
