{
  "info": {
    "name": "Kiwi General Insurance – D2C CMS API (Final Handover)",
    "description": "Comprehensive API collection for the optimized Insurance D2C CMS. Supports LOB > Product > Plan > Coverage hierarchy with keyword-based lookups.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:1337/api",
      "type": "string"
    },
    {
      "key": "jwt",
      "value": "REPLACE_WITH_JWT_TOKEN",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwt}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "🏥 D2C Insurance Hierarchy",
      "item": [
        {
          "name": "1. Line of Business (LOB)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/line-of-businesses?populate=*",
              "host": ["{{baseUrl}}"],
              "path": ["line-of-businesses"]
            },
            "description": "Fetch all LOBs with SEO, CTA, and UI Config."
          }
        },
        {
          "name": "2. Insurance Products (4W/2W Master)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/insurance-products?filters[uiConfig][isVisibleOnHomepage][$eq]=true&populate=*",
              "host": ["{{baseUrl}}"],
              "path": ["insurance-products"]
            },
            "description": "Fetch homepage product cards."
          }
        },
        {
          "name": "3. Insurance Plans (Tenures 1+3, 1+5)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/insurance-plans?filters[insuranceProduct][identifier][$eq]=4W&populate[inclusions][populate]=*&populate[addons][populate]=*&populate[faqs]=*&populate[seo]=*",
              "host": ["{{baseUrl}}"],
              "path": ["insurance-plans"]
            },
            "description": "Fetch specific plans for a vehicle type with full detail population."
          }
        }
      ]
    },
    {
      "name": "🔍 Keyword Engine (Registry)",
      "item": [
        {
          "name": "Lookup by Keyword (Single Source of Truth)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/coverages?filters[identifiers][$contains]=VOLDED_FLAG&populate=*",
              "host": ["{{baseUrl}}"],
              "path": ["coverages"]
            },
            "description": "Pull UI/UX content (headings, icons, tooltips) for a technical keyword."
          }
        }
      ]
    },
    {
      "name": "📄 Dynamic Page Builder",
      "item": [
        {
          "name": "Product Landing Page (Full Build)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/insurance-products?filters[slug][$eq]=car-insurance&populate[pageBuilder][on][page-builder.accordion][populate]=*&populate[pageBuilder][on][page-builder.banner][populate]=*&populate[seo]=*",
              "host": ["{{baseUrl}}"],
              "path": ["insurance-products"]
            },
            "description": "Fetch the full dynamic landing page for a specific product."
          }
        }
      ]
    }
  ]
}
