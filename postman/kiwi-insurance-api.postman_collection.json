{
  "info": {
    "name": "Kiwi General Insurance – COMPLETE API (Architect Optimized)",
    "description": "Comprehensive API collection for all endpoints, including deep population strategy for reusable components and SSOT product registry.\nBase URL: http://localhost:1337/api",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:1337/api", "type": "string" },
    { "key": "documentId", "value": "REPLACE_WITH_ID", "type": "string" },
    { "key": "jwt", "value": "REPLACE_WITH_JWT_TOKEN", "type": "string" }
  ],
  "item": [
    {
      "name": "🚀 System Brain",
      "item": [
        {
          "name": "Global Config (Branding & Regulatory)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/global-config?populate=*",
              "host": ["{{baseUrl}}"],
              "path": ["global-config"],
              "query": [
                { "key": "populate", "value": "*" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "📄 Dynamic Landing Pages",
      "item": [
        {
          "name": "Home Page (Deep Population)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/pages?filters[slug][$eq]=home&populate[content][on][page-builder.insurance-product-cta][populate]=product&populate[content][on][shared.section-reference][populate]=shared_section&populate[content][on][page-builder.hero-section][populate]=*&populate[content][on][page-builder.card-grid][populate]=*&populate[content][on][page-builder.accordion][populate]=*",
              "host": ["{{baseUrl}}"],
              "path": ["pages"],
              "query": [
                { "key": "filters[slug][$eq]", "value": "home" },
                { "key": "populate[content][on][page-builder.insurance-product-cta][populate]", "value": "product" },
                { "key": "populate[content][on][shared.section-reference][populate]", "value": "shared_section" },
                { "key": "populate[content][on][page-builder.hero-section][populate]", "value": "*" },
                { "key": "populate[content][on][page-builder.card-grid][populate]", "value": "*" },
                { "key": "populate[content][on][page-builder.accordion][populate]", "value": "*" }
              ]
            },
            "description": "Retrieves the Home page with all dynamic blocks, including reusable shared sections and dynamic product pricing."
          }
        }
      ]
    },
    {
      "name": "📰 Articles & Authors",
      "item": [
        {
          "name": "All Articles (with Author & Category)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/articles?populate=author,categories",
              "host": ["{{baseUrl}}"],
              "path": ["articles"],
              "query": [
                { "key": "populate", "value": "author,categories" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "🛡️ Product Registry (SSOT)",
      "item": [
        { "name": "Insurance Products", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/insurance-products", "host": ["{{baseUrl}}"], "path": ["insurance-products"] } } },
        { "name": "Standard IRDAI Products", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/standard-products", "host": ["{{baseUrl}}"], "path": ["standard-products"] } } }
      ]
    },
    {
      "name": "📍 Infrastructure",
      "item": [
        { "name": "Branches", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/branches", "host": ["{{baseUrl}}"], "path": ["branches"] } } },
        { "name": "Ombudsman Offices", "request": { "method": { "raw": "GET" }, "url": { "raw": "{{baseUrl}}/ombudsman-offices", "host": ["{{baseUrl}}"], "path": ["ombudsman-offices"] } } },
        { "name": "Grievance Levels", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/grievance-levels", "host": ["{{baseUrl}}"], "path": ["grievance-levels"] } } }
      ]
    }
  ]
}
