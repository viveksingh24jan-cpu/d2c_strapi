{
  "info": {
    "name": "Kiwi General Insurance – ULTIMATE API (Day 0 Architect)",
    "description": "Exhaustive API coverage for the Day 0 consolidated architecture. Includes deep population for rich Accordions, unified Banners, and SSOT Products.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:1337/api", "type": "string" },
    { "key": "jwt", "value": "REPLACE_WITH_JWT_TOKEN", "type": "string" }
  ],
  "item": [
    {
      "name": "🚀 System Brain",
      "item": [
        { "name": "Global Config", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/global-config?populate=*", "host": ["{{baseUrl}}"], "path": ["global-config"] } } }
      ]
    },
    {
      "name": "📄 Dynamic Landing Pages",
      "item": [
        {
          "name": "Home Page (Full Sync)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/pages?filters[slug][$eq]=home&populate[content][on][page-builder.insurance-product-cta][populate]=product&populate[content][on][shared.section-reference][populate]=shared_section&populate[content][on][page-builder.accordion][populate]=*&populate[content][on][page-builder.banner][populate]=*&populate[content][on][page-builder.hero-section][populate]=*",
              "host": ["{{baseUrl}}"],
              "path": ["pages"],
              "query": [
                { "key": "filters[slug][$eq]", "value": "home" },
                { "key": "populate[content][on][page-builder.insurance-product-cta][populate]", "value": "product" },
                { "key": "populate[content][on][shared.section-reference][populate]", "value": "shared_section" },
                { "key": "populate[content][on][page-builder.accordion][populate]", "value": "*" },
                { "key": "populate[content][on][page-builder.banner][populate]", "value": "*" }
              ]
            },
            "description": "Fetches the full page structure with consolidated Day 0 components."
          }
        }
      ]
    },
    {
      "name": "🛡️ Unified Product Registry",
      "item": [
        { "name": "All Products (SSOT)", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/insurance-products?populate=*", "host": ["{{baseUrl}}"], "path": ["insurance-products"] } } },
        { "name": "Standard Products Only", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/insurance-products?filters[isStandard][$eq]=true", "host": ["{{baseUrl}}"], "path": ["insurance-products"] } } }
      ]
    },
    {
      "name": "📰 Content Engine",
      "item": [
        { "name": "Articles (with blocks)", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/articles?populate=*", "host": ["{{baseUrl}}"], "path": ["articles"] } } },
        { "name": "Authors Registry", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/authors?populate=*", "host": ["{{baseUrl}}"], "path": ["authors"] } } }
      ]
    },
    {
      "name": "⚖️ Regulatory & Infra",
      "item": [
        { "name": "Branch Map Data", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/branches", "host": ["{{baseUrl}}"], "path": ["branches"] }, "description": "Returns geolocation data for map rendering." } },
        { "name": "Transparency Reports", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/transparency-reports", "host": ["{{baseUrl}}"], "path": ["transparency-reports"] } } }
      ]
    }
  ]
}
